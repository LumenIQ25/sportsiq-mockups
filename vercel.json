{
  "version": 2,
  "routes": [
    { "src": "/api/health",   "dest": "/api/health.js" },
    { "src": "/api/reply",    "dest": "/api/reply.js" },
    { "src": "/api/new-idea", "dest": "/api/new-idea.js" },
    { "src": "/api/threads",  "dest": "/api/threads.js" },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Pragma": "no-cache",
        "Expires": "0"
      }
    }
  ]
}
